# Copy this file to .env and fill in real values before running docker compose up.
# Never commit the real .env file.

# --- PostgreSQL ---
POSTGRES_DB=jrv_impact
POSTGRES_USER=jrv_user
POSTGRES_PASSWORD=change_this_to_a_strong_password

# --- JWT auth ---
# Generate a long random string, e.g.: openssl rand -base64 48
JWT_KEY=change_this_to_a_long_random_secret_at_least_32_characters
JWT_ISSUER=JrvImpact
JWT_AUDIENCE=JrvImpactClient
JWT_EXPIRY_HOURS=12

# --- Seeded default admin user (change the password after first login) ---
ADMIN_PASSWORD=Admin@123

# --- Networking ---
# Public URL the app will be reached at (used for CORS). Update once you have a
# domain / reverse proxy in front, e.g. https://jrv.yourdomain.com
PUBLIC_URL=http://localhost
HTTP_PORT=80

ASPNETCORE_ENVIRONMENT=Production
